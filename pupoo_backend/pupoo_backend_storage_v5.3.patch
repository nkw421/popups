+// file: src/main/java/com/popups/pupoo/gallery/dto/GalleryImageUploadResponse.java
+package com.popups.pupoo.gallery.dto;
+
+import com.popups.pupoo.gallery.domain.model.GalleryImage;
+import lombok.AllArgsConstructor;
+import lombok.Builder;
+import lombok.Getter;
+import lombok.NoArgsConstructor;
+
+import java.time.LocalDateTime;
+
+@Getter
+@Builder
+@NoArgsConstructor
+@AllArgsConstructor
+public class GalleryImageUploadResponse {
+
+    private Long imageId;
+    private Long galleryId;
+    private String originalUrl;
+    private String thumbUrl;
+    private Integer imageOrder;
+    private String mimeType;
+    private Integer fileSize;
+    private LocalDateTime createdAt;
+
+    public static GalleryImageUploadResponse from(GalleryImage img) {
+        if (img == null) return null;
+
+        return GalleryImageUploadResponse.builder()
+                .imageId(img.getImageId())
+                .galleryId(img.getGalleryId())
+                .originalUrl(img.getOriginalUrl())
+                .thumbUrl(img.getThumbUrl())
+                .imageOrder(img.getImageOrder())
+                .mimeType(img.getMimeType())
+                .fileSize(img.getFileSize())
+                .createdAt(img.getCreatedAt())
+                .build();
+    }
+}
