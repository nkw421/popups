+// file: src/main/java/com/popups/pupoo/gallery/application/GalleryImageUploadService.java
+package com.popups.pupoo.gallery.application;
+
+import com.popups.pupoo.common.exception.BusinessException;
+import com.popups.pupoo.common.exception.ErrorCode;
+import com.popups.pupoo.gallery.domain.enums.GalleryStatus;
+import com.popups.pupoo.gallery.domain.model.Gallery;
+import com.popups.pupoo.gallery.domain.model.GalleryImage;
+import com.popups.pupoo.gallery.dto.GalleryImageUploadResponse;
+import com.popups.pupoo.gallery.persistence.GalleryImageRepository;
+import com.popups.pupoo.gallery.persistence.GalleryRepository;
+import com.popups.pupoo.storage.infrastructure.StorageKeyGenerator;
+import com.popups.pupoo.storage.port.ObjectStoragePort;
+import org.springframework.stereotype.Service;
+import org.springframework.transaction.annotation.Transactional;
+import org.springframework.web.multipart.MultipartFile;
+
+import java.io.IOException;
+import java.time.LocalDateTime;
+import java.util.ArrayList;
+import java.util.HashSet;
+import java.util.List;
+import java.util.Locale;
+import java.util.Set;
+
+@Service
+@Transactional(readOnly = true)
+public class GalleryImageUploadService {
+
+    private static final String LOCAL_BUCKET_UNUSED = "local";
+
+    private static final Set<String> ALLOWED_IMAGE_TYPES = new HashSet<>(
+            List.of("jpeg", "jpg", "png", "gif", "webp", "tiff", "svg")
+    );
+
+    private final GalleryRepository galleryRepository;
+    private final GalleryImageRepository galleryImageRepository;
+
+    private final ObjectStoragePort objectStoragePort;
+    private final StorageKeyGenerator storageKeyGenerator;
+
+    public GalleryImageUploadService(GalleryRepository galleryRepository,
+                                    GalleryImageRepository galleryImageRepository,
+                                    ObjectStoragePort objectStoragePort,
+                                    StorageKeyGenerator storageKeyGenerator) {
+        this.galleryRepository = galleryRepository;
+        this.galleryImageRepository = galleryImageRepository;
+        this.objectStoragePort = objectStoragePort;
+        this.storageKeyGenerator = storageKeyGenerator;
+    }
+
+    /**
+     * 갤러리 이미지 업로드
+     *
+     * 저장 규칙
+     * - basePath: ./uploads
+     * - key: gallery/{galleryId}/{uuid.ext}
+     * - publicPath: /static/{key}
+     *
+     * DB 기록(v5.3)
+     * - gallery_images.original_url 에 publicPath 저장
+     * - galleries.thumbnail_image_id 가 비어있으면, 첫 업로드 이미지를 대표 이미지로 설정
+     */
+    @Transactional
+    public List<GalleryImageUploadResponse> uploadImages(Long galleryId,
+                                                        Long currentUserId,
+                                                        boolean isAdmin,
+                                                        List<MultipartFile> files) {
+        if (galleryId == null || galleryId <= 0) {
+            throw new BusinessException(ErrorCode.VALIDATION_FAILED, "galleryId is required");
+        }
+        if (files == null || files.isEmpty()) {
+            throw new BusinessException(ErrorCode.VALIDATION_FAILED, "files is required");
+        }
+
+        Gallery gallery = galleryRepository.findById(galleryId)
+                .orElseThrow(() -> new BusinessException(ErrorCode.RESOURCE_NOT_FOUND, "gallery not found"));
+
+        validateUploadPermission(gallery, currentUserId, isAdmin);
+
+        Integer maxOrder = galleryImageRepository.findMaxImageOrder(galleryId);
+        int nextOrder = (maxOrder == null) ? 1 : maxOrder + 1;
+
+        List<GalleryImageUploadResponse> results = new ArrayList<>();
+        Long firstNewImageId = null;
+
+        for (MultipartFile file : files) {
+            if (file == null || file.isEmpty()) {
+                continue;
+            }
+
+            String originalName = safeOriginalName(file.getOriginalFilename());
+            String resolvedType = resolveImageType(file.getContentType(), originalName);
+            validateImageType(resolvedType);
+
+            String key = storageKeyGenerator.generateKey(StorageKeyGenerator.UploadTargetType.GALLERY, galleryId, originalName);
+
+            try {
+                objectStoragePort.putObject(LOCAL_BUCKET_UNUSED, key, file.getBytes(), file.getContentType());
+            } catch (IOException e) {
+                throw new BusinessException(ErrorCode.INTERNAL_ERROR, "Failed to read upload bytes: " + e.getMessage());
+            }
+
+            String publicPath = objectStoragePort.getPublicPath(LOCAL_BUCKET_UNUSED, key);
+            Integer fileSize = safeIntSize(file.getSize());
+
+            GalleryImage image = GalleryImage.builder()
+                    .gallery(gallery)
+                    .originalUrl(publicPath)
+                    .thumbUrl(null)
+                    .imageOrder(nextOrder++)
+                    .mimeType(resolvedType)
+                    .fileSize(fileSize)
+                    .createdAt(LocalDateTime.now())
+                    .build();
+
+            GalleryImage saved = galleryImageRepository.save(image);
+
+            if (firstNewImageId == null) {
+                firstNewImageId = saved.getImageId();
+            }
+
+            results.add(GalleryImageUploadResponse.from(saved));
+        }
+
+        if (results.isEmpty()) {
+            throw new BusinessException(ErrorCode.VALIDATION_FAILED, "no files uploaded");
+        }
+
+        if (gallery.getThumbnailImageId() == null && firstNewImageId != null) {
+            galleryRepository.save(gallery.toBuilder()
+                    .thumbnailImageId(firstNewImageId)
+                    .updatedAt(LocalDateTime.now())
+                    .build());
+        }
+
+        return results;
+    }
+
+    private void validateUploadPermission(Gallery gallery, Long currentUserId, boolean isAdmin) {
+        if (gallery.getGalleryStatus() == GalleryStatus.DELETED) {
+            throw new BusinessException(ErrorCode.INVALID_REQUEST, "gallery is deleted");
+        }
+
+        if (isAdmin) {
+            return;
+        }
+
+        if (currentUserId == null) {
+            throw new BusinessException(ErrorCode.UNAUTHORIZED, "UNAUTHENTICATED");
+        }
+        if (!currentUserId.equals(gallery.getUserId())) {
+            throw new BusinessException(ErrorCode.FORBIDDEN, "only author can upload images");
+        }
+
+        if (gallery.getGalleryStatus() == GalleryStatus.BLINDED) {
+            throw new BusinessException(ErrorCode.FORBIDDEN, "blinded gallery cannot be modified by user");
+        }
+    }
+
+    private void validateImageType(String type) {
+        if (type == null || type.isBlank()) {
+            throw new BusinessException(ErrorCode.VALIDATION_FAILED, "image type is required");
+        }
+        if (!ALLOWED_IMAGE_TYPES.contains(type)) {
+            throw new BusinessException(ErrorCode.VALIDATION_FAILED, "unsupported image type: " + type);
+        }
+    }
+
+    private String resolveImageType(String contentType, String originalName) {
+        String ext = extractExt(originalName);
+        if (ext != null && !ext.isBlank()) {
+            return ext.toLowerCase(Locale.ROOT);
+        }
+
+        if (contentType == null || contentType.isBlank()) {
+            return null;
+        }
+
+        String ct = contentType.toLowerCase(Locale.ROOT);
+        return switch (ct) {
+            case "image/jpeg" -> "jpeg";
+            case "image/jpg" -> "jpg";
+            case "image/png" -> "png";
+            case "image/gif" -> "gif";
+            case "image/webp" -> "webp";
+            case "image/tiff" -> "tiff";
+            case "image/svg+xml" -> "svg";
+            default -> null;
+        };
+    }
+
+    private static Integer safeIntSize(long size) {
+        if (size < 0) return null;
+        if (size > Integer.MAX_VALUE) {
+            throw new BusinessException(ErrorCode.VALIDATION_FAILED, "file is too large");
+        }
+        return (int) size;
+    }
+
+    private static String extractExt(String filename) {
+        if (filename == null) return null;
+        int idx = filename.lastIndexOf('.');
+        if (idx < 0 || idx == filename.length() - 1) return null;
+        return filename.substring(idx + 1);
+    }
+
+    private static String safeOriginalName(String originalFilename) {
+        if (originalFilename == null || originalFilename.isBlank()) return "file";
+        int idx1 = originalFilename.lastIndexOf('/');
+        int idx2 = originalFilename.lastIndexOf('\\');
+        int idx = Math.max(idx1, idx2);
+        return (idx >= 0) ? originalFilename.substring(idx + 1) : originalFilename;
+    }
+}
