# =========================
# Spring / Server
# =========================
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=true
LOGGING_LEVEL_HIBERNATE_SQL=debug
LOGGING_LEVEL_HIBERNATE_BIND=trace
SPRING_SQL_INIT_MODE=never
SPRING_SQL_INIT_SCHEMA_LOCATIONS=optional:classpath:db/password_reset_token.sql

# =========================
# MySQL
# =========================
SPRING_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/pupoodb?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useUnicode=true&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=pupoo
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_DATASOURCE_HIKARI_MAX_POOL_SIZE=10
SPRING_DATASOURCE_HIKARI_MIN_IDLE=2
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_HIKARI_VALIDATION_TIMEOUT=5000

# =========================
# JWT / Verification
# =========================
AUTH_JWT_SECRET=PLEASE_CHANGE_THIS_TO_A_STRONG_BASE64_SECRET
AUTH_JWT_ISSUER=pupoo
AUTH_ACCESS_TTL_SECONDS=3600
AUTH_REFRESH_TTL_SECONDS=1209600
AUTH_REFRESH_COOKIE_MAX_AGE_SECONDS=1209600
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_HTTP_ONLY=true
AUTH_REFRESH_COOKIE_SAME_SITE=Lax
AUTH_REFRESH_COOKIE_PATH=/api/auth
VERIFICATION_HASH_SALT=PLEASE_CHANGE_THIS_TO_A_STRONG_RANDOM_SALT
VERIFICATION_DEV_EXPOSE=false
AUTH_EMAIL_PROVIDER=aws-ses
AUTH_SMS_PROVIDER=aws-sns
AUTH_SMS_ENABLED=true
AUTH_SMS_OTP_EXPIRY_SECONDS=300
AUTH_SMS_RESEND_COOLDOWN_SECONDS=60
AUTH_SMS_MAX_REQUESTS_PER_MINUTE=1
AUTH_SMS_MAX_REQUESTS_PER_DAY=5
AUTH_SMS_MAX_VERIFY_FAILURES=5
AWS_REGION=ap-northeast-2
AWS_SMS_REGION=ap-northeast-1
AWS_AUTH_MESSAGING_ACCESS_KEY_ID=
AWS_AUTH_MESSAGING_SECRET_ACCESS_KEY=
AWS_AUTH_MESSAGING_SESSION_TOKEN=
AWS_SES_FROM_ADDRESS=
AWS_SES_FROM_NAME=
AWS_SMS_ORIGINATION_NUMBER=
AWS_SMS_SENDER_ID=
VERIFICATION_EMAIL_BASE_URL=
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://3.38.233.224,http://3.38.233.224:8080,http://*.duckdns.org,https://*.duckdns.org,https://pupoo.site,https://www.pupoo.site

# =========================
# Redis
# =========================
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
SPRING_DATA_REDIS_DATABASE=0
SPRING_DATA_REDIS_TIMEOUT=2s

# =========================
# Kakao OAuth
# =========================
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=
KAKAO_OAUTH_REDIRECT_URI=https://www.pupoo.site/auth/kakao/callback

# =========================
# Naver OAuth
# =========================
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=
NAVER_OAUTH_REDIRECT_URI=https://www.pupoo.site/naver/callback

# =========================
# KakaoPay
# =========================
APP_FRONTEND_BASE_URL=http://localhost:5173
KAKAOPAY_BASE_URL=https://open-api.kakaopay.com
KAKAOPAY_SECRET_KEY=
KAKAOPAY_AUTH_PREFIX=SECRET_KEY 
KAKAOPAY_CID=TC0ONETIME
KAKAOPAY_READY_PATH=/online/v1/payment/ready
KAKAOPAY_APPROVE_PATH=/online/v1/payment/approve
KAKAOPAY_CANCEL_PATH=/online/v1/payment/cancel
KAKAOPAY_APPROVAL_URL=http://localhost:5173/payment/approve?paymentId={paymentId}
KAKAOPAY_CANCEL_URL=http://localhost:5173/payment/cancel?paymentId={paymentId}
KAKAOPAY_FAIL_URL=http://localhost:5173/payment/fail?paymentId={paymentId}

# =========================
# AI Congestion Service
# =========================
AI_SERVICE_BASE_URL=http://ai:8000
AI_SERVICE_INTERNAL_TOKEN=dev-internal-token
AI_SERVICE_CONNECT_TIMEOUT_MS=500
AI_SERVICE_RESPONSE_TIMEOUT_MS=3000
AI_SERVICE_MAX_IN_MEMORY_SIZE_BYTES=5242880
AI_SCHEDULER_ENABLED=true
AI_SCHEDULER_FIXED_DELAY_MS=300000
AI_SCHEDULER_INITIAL_DELAY_MS=30000
AI_AGGREGATION_SCHEDULER_CRON=0 */5 * * * *
AI_AGGREGATION_SCHEDULER_ZONE=Asia/Seoul

# =========================
# OpenAI Image Generation
# =========================
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_IMAGE_BASE_URL=https://api.openai.com

# =========================
# AI Moderation
# =========================
AI_MODERATION_ENABLED=true
AI_MODERATION_BASE_URL=http://ai:8000
AI_MODERATION_INTERNAL_TOKEN=dev-internal-token
AI_MODERATION_CONNECT_TIMEOUT_MS=3000
AI_MODERATION_READ_TIMEOUT_MS=8000

# =========================
# Storage
# =========================
APP_STORAGE_MODE=local
APP_STORAGE_BASE_PATH=./uploads
APP_STORAGE_PUBLIC_PREFIX=/uploads
APP_STORAGE_KEY_PREFIX=uploads
APP_STORAGE_PUBLIC_BASE_URL=http://localhost:8080
APP_STORAGE_CDN_BASE_URL=https://cdn.pupoo.site
APP_STORAGE_BUCKET=
APP_STORAGE_REGION=ap-northeast-2
APP_STORAGE_ACCESS_KEY_ID=
APP_STORAGE_SECRET_ACCESS_KEY=
APP_STORAGE_SESSION_TOKEN=

# Legacy storage aliases still supported
STORAGE_TYPE=local
STORAGE_MODE=local
STORAGE_BASE_PATH=./uploads
STORAGE_PUBLIC_PREFIX=/uploads
STORAGE_KEY_PREFIX=uploads
STORAGE_BUCKET=
STORAGE_REGION=ap-northeast-2
STORAGE_PUBLIC_BASE_URL=http://localhost:8080
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_SESSION_TOKEN=

# AWS SDK DefaultCredentialsProvider
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
