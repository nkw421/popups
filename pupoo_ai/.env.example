# 서비스
PUPOO_AI_SERVICE_NAME=pupoo-ai
PUPOO_AI_LOG_LEVEL=INFO
PUPOO_AI_INTERNAL_TOKEN=dev-internal-token

# watsonx.ai (금지어 RAG: LLM)
PUPOO_AI_WATSONX_API_KEY=
PUPOO_AI_WATSONX_URL=https://us-south.ml.cloud.ibm.com
PUPOO_AI_WATSONX_PROJECT_ID=your-project-id
PUPOO_AI_WATSONX_REGION=us-south
PUPOO_AI_WATSONX_LLM_ID=ibm/granite-13b-instruct-v2

# 임베딩 백엔드: bge-m3 (권장) | ""(설정 없으면 watsonx 또는 Stub)
PUPOO_AI_EMBEDDING_BACKEND=bge-m3
PUPOO_AI_WATSONX_EMBEDDING_MODEL_ID=
PUPOO_AI_WATSONX_EMBEDDING_DIM=1024

# Milvus (정책 벡터 저장소). Windows에서 연결 실패 시 127.0.0.1 사용
PUPOO_AI_MILVUS_HOST=127.0.0.1
PUPOO_AI_MILVUS_PORT=19530
PUPOO_AI_MILVUS_TLS=false
PUPOO_AI_MILVUS_USERNAME=
PUPOO_AI_MILVUS_PASSWORD=
PUPOO_AI_MILVUS_COLLECTION=policy_vectors
