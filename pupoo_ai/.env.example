PORT=8000
PUPOO_AI_SERVICE_NAME=pupoo-ai
PUPOO_AI_LOG_LEVEL=INFO
PUPOO_AI_INTERNAL_TOKEN=dev-internal-token
PUPOO_AI_AWS_REGION=us-east-1
PUPOO_AI_BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
PUPOO_AI_REDIS_URL=redis://localhost:6379/0
PUPOO_AI_DB_URL=
PUPOO_AI_DB_HOST=
PUPOO_AI_DB_PORT=3306
PUPOO_AI_DB_USER=
PUPOO_AI_DB_PASSWORD=
PUPOO_AI_DB_NAME=
PUPOO_AI_DB_CHARSET=utf8mb4
PUPOO_AI_DB_CONNECT_TIMEOUT=5
PUPOO_AI_DB_READ_TIMEOUT=10
PUPOO_AI_DB_WRITE_TIMEOUT=10
PUPOO_AI_DB_SSL_CA=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# watsonx.ai (금지어 RAG: LLM + 임베딩)
PUPOO_AI_WATSONX_API_KEY=
PUPOO_AI_WATSONX_URL=https://us-south.ml.cloud.ibm.com
PUPOO_AI_WATSONX_PROJECT_ID=your-project-id
PUPOO_AI_WATSONX_REGION=us-south
PUPOO_AI_WATSONX_LLM_ID=ibm/granite-13b-instruct-v2
# 정책 Milvus 검색용 임베딩 (모델 카드의 벡터 차원과 DIM을 반드시 일치)
PUPOO_AI_WATSONX_EMBEDDING_MODEL_ID=ibm/granite-embedding-278m-multilingual
PUPOO_AI_WATSONX_EMBEDDING_DIM=768

# Milvus (정책 벡터 저장소). Windows에서 연결 실패 시 127.0.0.1 사용
PUPOO_AI_MILVUS_HOST=127.0.0.1
PUPOO_AI_MILVUS_PORT=19530
PUPOO_AI_MILVUS_TLS=false
PUPOO_AI_MILVUS_USERNAME=
PUPOO_AI_MILVUS_PASSWORD=
PUPOO_AI_MILVUS_COLLECTION=policy_vectors
