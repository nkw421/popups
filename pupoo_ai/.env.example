# ============================================
# pupoo_ai 환경변수 설정
# 이 파일을 복사해서 .env로 만들고 값을 채워주세요
# cp .env.example .env
# ============================================

APP_NAME=pupoo-ai
APP_ENV=local
APP_PORT=8000
INTERNAL_TOKEN=dev-internal-token
LOG_LEVEL=INFO
REDIS_URL=redis://localhost:6379/0
BACKEND_BASE_URL=http://localhost:8080

# AWS Bedrock (챗봇 AI)
# IAM 콘솔 → 보안 자격 증명 → 액세스 키 만들기에서 발급
# 해당 IAM 사용자에 AmazonBedrockFullAccess 정책 필요
PUPOO_AI_AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=여기에_액세스_키_ID
AWS_SECRET_ACCESS_KEY=여기에_시크릿_액세스_키
