# API
# - Set path prefixes only. Requests already containing /api or /ai are normalized to avoid duplicates.
# - For local dev, Vite proxy(/api -> http://localhost:8080, /ai -> http://localhost:8000) is used by default.
VITE_API_BASE_URL=/api
VITE_AI_BASE_URL=/ai
VITE_ASSET_BASE_URL=

# Kakao OAuth (site login)
VITE_KAKAO_REST_KEY=
VITE_KAKAO_REDIRECT_URI=

# Kakao Map (optional)
VITE_KAKAO_MAP_KEY=b338ac0a2a4b79c4fdffe57afe4591c4
