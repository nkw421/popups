VITE_AI_BASE_URL=/ai
VITE_CDN_BASE_URL=https://cdn.pupoo.site
VITE_ASSET_BASE_URL=

# Kakao OAuth (site login)
VITE_KAKAO_REST_KEY=
VITE_KAKAO_REDIRECT_URI=

# Naver OAuth (site login)
VITE_NAVER_CLIENT_ID=
VITE_NAVER_REDIRECT_URI=https://www.pupoo.site/naver/callback

# Kakao Map (optional)
